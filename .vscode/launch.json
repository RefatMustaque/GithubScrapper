{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (HTTPS)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/GithubScrapper/GithubScrapper/GithubScrapper/bin/Debug/net8.0/GithubScrapper.dll",
            "args": [],
            "cwd": "${workspaceFolder}/GithubScrapper/GithubScrapper/GithubScrapper",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001"
            },
            "launchBrowser": {
                "enabled": true,
                "args": "https://localhost:5001",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start https://localhost:5001"
                },
                "osx": {
                    "command": "open"
                },
                "linux": {
                    "command": "xdg-open"
                }
            }
        }
    ]
}
