@{
    ViewData["Title"] = "";
    var isAuthenticated = User?.Identity is { IsAuthenticated: true };
}

<div class="container py-5">
    <section class="hero-section text-center mb-5 p-5 rounded shadow-lg bg-gradient position-relative overflow-hidden" style="background: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 100%); min-height: 420px;">
        <div class="row align-items-center justify-content-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-3 fw-bold mb-3" style="color: #2d3748;">Welcome to <span style="color: #6366f1;">GitHub Scrapper</span></h1>
                <p class="lead mb-4" style="color: #4b5563;">Your ultimate tool for scraping GitHub repositories easily and efficiently!</p>
                @if (!isAuthenticated)
                {
                    <h2 class="h4 mt-4" style="color: #6366f1;">How it Works</h2>
                    <p class="mb-0" style="color: #6b7280;">GitHub Scrapper allows you to easily scrape public GitHub repository data. Simply login and start scraping repositories to gather information for your projects! You can download your results as a single TXT file or an interactive HTML file.</p>
                }
            </div>
            <div class="col-lg-6 d-flex justify-content-center">
                <img src="~/images/github-scrapper-hero.jpg" alt="GitHub Scrapper Hero" class="img-fluid rounded-4 shadow" style="max-height: 320px; object-fit: cover; border: 4px solid #6366f1; background: #fff;" />
            </div>
        </div>
    </section>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg mt-5" style="border-radius: 1.5rem;">
                <div class="card-body p-5">
                    @if (!isAuthenticated)
                    {
                        <h2 class="h4 mb-3" style="color: #6366f1;">Authentication</h2>
                        <p class="mb-4" style="color: #6b7280;">Login to access advanced features and start scraping your favorite repositories!</p>
                    }

                    <section class="container mt-4 text-center">
                        @if (isAuthenticated)
                        {
                            <h2 class="h4 mb-3" style="color: #6366f1;">How it works</h2>
                            <p class="mb-4" style="color: #6b7280;">GitHub Scrapper allows you to easily scrape public GitHub repository data. Simply login and start scraping repositories to gather information for your projects! You can download your results as a single TXT file or an interactive HTML file.</p>
                            <a href="/Github/ScrapeRepositories" class="btn btn-lg btn-primary px-5 py-2 shadow-sm" style="border-radius: 2rem; background: linear-gradient(90deg, #6366f1 0%, #60a5fa 100%); border: none;">Start Scraping</a>
                        }
                        else
                        {
                            <a class="btn btn-lg btn-primary mt-3 px-5 py-2 shadow-sm d-flex align-items-center justify-content-center gap-2" asp-controller="Account" asp-action="Login" style="border-radius: 2rem; background: linear-gradient(90deg, #6366f1 0%, #60a5fa 100%); border: none;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.157-1.11-1.465-1.11-1.465-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.339-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.847-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .267.18.577.688.479C19.138 20.2 22 16.447 22 12.021 22 6.484 17.523 2 12 2Z" fill="#181717"/></svg>
                                Login with GitHub
                            </a>
                        }
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modern look: gradients, rounded corners, shadow, larger buttons, and color highlights. -->


