<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Explore Refat Bin Mustaque's project showcasing expertise on scraping github project and repositories.">
    <title>@ViewData["Title"] - GitHub Scrapper - Refat Bin Mustaque</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GithubScrapper.styles.css" asp-append-version="true" />
</head>
<!-- update again comment to test -->
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4 shadow-lg" style="background: linear-gradient(90deg, #6366f1 0%, #60a5fa 100%); border-radius: 0 0 1.5rem 1.5rem;">
            <div class="container-fluid py-2">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-controller="Home" asp-action="Index" style="font-size: 2rem; letter-spacing: 1px;">GitHub Scrapper</a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-semibold px-3" asp-area="" asp-controller="Github" asp-action="ScrapeRepositories">Scrape Repositories</a>
                        </li>
                        <!-- Privacy link removed from topbar -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white fw-semibold px-3" href="#" id="personalLinksDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                More Links
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="personalLinksDropdown">
                                <li><a class="dropdown-item" href="https://refatmustaque.com" target="_blank" rel="noopener" title="Refat Mustaque's Portfolio">My Portfolio</a></li>
                                <li><a class="dropdown-item" href="https://blog.refatmustaque.com" target="_blank" rel="noopener" title="Refat Mustaque's Blog">Blog</a></li>
                                <li><a class="dropdown-item" href="https://linkedin.com/in/refatmustaque" target="_blank" rel="noopener" title="Refat Mustaque on LinkedIn">LinkedIn</a></li>
                                <li><a class="dropdown-item" href="https://github.com/refatmustaque" target="_blank" rel="noopener" title="Refat Mustaque on GitHub">GitHub</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">Hello, @User.FindFirst("urn:github:login")?.Value!</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    <button type="submit" class="btn btn-light text-primary fw-bold shadow-sm px-4" style="border-radius: 2rem;">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-light text-primary fw-bold shadow-sm px-4 d-flex align-items-center gap-2" asp-controller="Account" asp-action="Login" style="border-radius: 2rem;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.157-1.11-1.465-1.11-1.465-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.339-2.221-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.847-2.337 4.695-4.566 4.944.359.309.678.919.678 1.852 0 1.336-.012 2.417-.012 2.747 0 .267.18.577.688.479C19.138 20.2 22 16.447 22 12.021 22 6.484 17.523 2 12 2Z" fill="#181717"/></svg>
                                    Login with GitHub
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="content-wrapper">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2024 - GitHub Scrapper  
            | <a asp-area="" asp-controller="Home" asp-action="Privacy" class="link-primary text-decoration-underline">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script type="text/javascript">
        // Call updateRateLimitInfo every 2 seconds (2000 milliseconds)
        // Note: This will make an API call every 2 seconds, which may contribute to hitting the rate limit faster. Use with caution.
        //setInterval(updateRateLimitInfo, 2000);
        let ajaxCallCount = 0;
        let updateRateLimitCall = 0;


        $(document).ajaxSend(function () {
            ajaxCallCount++;

            if (ajaxCallCount === 1 && updateRateLimitCall == 0) { // Show modal only when the first request starts
                // debugger;
                $("#modal-loading").fadeIn(250);
            }

        });

        $(document).ajaxComplete(function () {
            ajaxCallCount--;

            if (ajaxCallCount === 0) { // Hide modal only when all requests are completed
                // debugger;
                $("#modal-loading").fadeOut(250);
            }
        });
        function updateRateLimitInfo() {
            updateRateLimitCall = 1;
            $.ajax({
                url: '@Url.Action("GetRateLimitStatus", "Github")',
                method: 'GET',
                success: function (data) {
                    updateRateLimitCall = 0;
                    const resetTime = new Date(data.resetTime).toLocaleTimeString(); // Convert reset time to local format
                    let message = '';
                    if(data.remaining == 0)
                    {
                        message = `Sorry you have reached the api limit. Please try again after ${resetTime}`;
                    }
                    else{
                        message = `API Rate Limit: ${data.remaining} remaining out of ${data.total} (Reset at ${resetTime})`;
                    }

                    $('.rateLimitInfo').text(message);
                },
                error: function () {
                    updateRateLimitCall = 0;
                    $('.rateLimitInfo').text('API Rate Limit: Error');
                },
                complete:function (){
                    updateRateLimitCall = 0;
                }
            });
        }
    </script>

</body>
<div class="modal" id="modal-loading" style="z-index:99999999999999999999" data-backdrop="static" data-bs-backdrop='static'>
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center" >
                <div class="loading-spinner mb-2"></div>
                <div>Loading</div>
                <div id="rateLimitInfoModalId" style="display:none;" class="rateLimitInfo"></div>
            </div>
        </div>
    </div>
</div>

</html>
